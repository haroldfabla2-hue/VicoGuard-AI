# ═══════════════════════════════════════════════════════════
# VicoGuard AI — Environment Configuration
# ═══════════════════════════════════════════════════════════
# Copy to .env and fill in your credentials:
#   cp .env.example .env

# ── LLM Provider (Z.ai Coding Plan) ────────────────────────
# Primary: Z.ai GLM-5.2 (Coding Plan)
ZAI_CODING_PLAN_KEY=your_zai_coding_plan_key_here
ZAI_MODEL=glm-5.2

# Fallback 1: OpenAI (optional)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# Fallback 2: Anthropic Claude (optional)
# CLAUDE_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-sonnet-4-20250514

# ── Legacy compat (deprecated, use ZAI_CODING_PLAN_KEY) ────
# ANTHROPIC_API_KEY=same_zai_key  # old name, still works

# ── Telegram Bot (optional) ────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Server ─────────────────────────────────────────────────
VG_PORT=8000
VG_COOKIE_SECURE=0
VG_ENABLE_DOCS=1

# ── Redis (auto-configured by docker-compose) ──────────────
REDIS_URL=redis://vicoguard-redis:6379/1

# ============================================================
# VicoGuard AI & WASP Sentinel — Variables de Entorno (Unified)
# ============================================================
# Copia este archivo como .env y rellena los valores reales:
#   cp .env.example .env
#
# NUNCA subas el archivo .env a Git.
# ============================================================

# --- LLM API Keys ---
# OpenAI (Requerida para VicoGuard gpt-4o por defecto)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini (Alternativa gratuita en Google AI Studio)
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic (Requerida para el intérprete de WASP)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Telegram (Notificaciones y Comandos Bot) ---
# Habla con @BotFather en Telegram para crear tu bot
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=123456789

# --- WASP Node & Network Configuration ---
WASP_NETWORK_URL=http://localhost:8000
WASP_NODE_ID=nodo-local

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000

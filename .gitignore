*.pyc
*.pyo
*.pyd
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/
*.egg

# Virtual environments
.venv/
venv/
env/
.pytest_cache/

# IDE & OS
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# Secrets & tokens — NEVER commit these
.env
*.env
token*.json
credentials.json
client_secret*.json

# Databases & Runtime Data
*.db
*.db-wal
*.db-shm
*.sqlite3-wal
*.sqlite3-shm
vicoguard_app.db
data/
src/data/
centinela/data/

# Temporary & logs
*.log
*.tmp
full_transcript.txt

# Node (if any)
node_modules/

# PDF papers (too large for git)
docs_pdf/

# Agent internals
.agents/**/cache/
.agents/**/*.tmp
.agents/**/sessions/

# WASP binaries (auto-downloaded, do not version)
bin/*.exe
bin/*.zip

# Test fixture state
tests/fixtures/*.json
tests/fixtures/vuln_sample_repo/app.db
tests/fixtures/vuln_sample_repo/__pycache__/

